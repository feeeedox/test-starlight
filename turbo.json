{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "interactive": true,
      "persistent": true
    },
    "stub": {
      "cache": false
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".nuxt/**",
        "!.nuxt/cache/**",
        "dist/**",
        ".astro/**"
      ]
    },
    "lint": {},
    "lint:fix": {},
    "test": {},
    "test:e2e": {}
  }
}